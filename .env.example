# Supabase public client config.
# For new Supabase projects, prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY remains supported for older projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only database config. Never expose these values in client components.
# DATABASE_URL is required for migrations and the current deployment health check.
# SUPABASE_SERVICE_ROLE_KEY is intentionally optional for now.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Optional AI provider config.
# Leave these blank for the first no-AI deployment; programmatic stats still work.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_DAILY=
AI_MODEL_WEEKLY=
AI_MODEL_MONTHLY=

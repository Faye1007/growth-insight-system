# Supabase public client config.
# For new Supabase projects, prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
# NEXT_PUBLIC_SUPABASE_ANON_KEY remains supported for older projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase config. Never expose these values in client components.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# AI provider config for later steps.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_DAILY=
AI_MODEL_WEEKLY=
AI_MODEL_MONTHLY=
